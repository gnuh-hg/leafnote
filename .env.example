# Leafnote - Environment Variables Template
# Copy this file to .env and fill in the values.

# --- Backend Configuration (For Render / Server) ---
# Database (PostgreSQL with pgvector)
# MANDATORY: URL must start with 'postgresql+asyncpg://'
DATABASE_URL=postgresql+asyncpg://postgres:[password]@[host]:5432/postgres
DATABASE_POOLER_URL=postgresql+asyncpg://postgres.[ref]:[password]@aws-0-ap-southeast-1.pooler.supabase.com:6543/postgres

# Supabase Auth & Storage
# SUPABASE_URL: Project URL from API settings
SUPABASE_URL=https://[ref].supabase.co
# SUPABASE_SERVICE_ROLE_KEY: 'service_role' secret key (keep private)
SUPABASE_SERVICE_ROLE_KEY=[service-role-key]
# SUPABASE_JWT_SECRET: Found in Project Settings > API > JWT Settings > JWT Secret
SUPABASE_JWT_SECRET=[jwt-secret-from-supabase]

# Security & Environment
SECRET_KEY=[random-32-plus-characters]
ENVIRONMENT=production # Use 'production' for Render, 'development' for local

# CORS Settings (JSON list of allowed origins)
# Example for your Vercel + Local setup:
CORS_ORIGINS=["https://leafnote-vn.vercel.app","http://localhost:5173"]

# Redis (Required for AI tasks)
REDIS_URL=redis://localhost:6379

# --- Frontend Configuration (For Vercel / Client) ---
# VITE_SUPABASE_URL: Same as SUPABASE_URL above
VITE_SUPABASE_URL=https://[ref].supabase.co
# VITE_SUPABASE_ANON_KEY: 'anon' public key
VITE_SUPABASE_ANON_KEY=[anon-key]

# VITE_API_URL: Your Backend URL on Render (e.g., https://leafnote-api.onrender.com)
VITE_API_URL=http://localhost:8000
