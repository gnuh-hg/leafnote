# Transaction Pooler (port 6543) — used by the app at runtime.
DATABASE_URL=postgresql+asyncpg://postgres.<ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres

# Session Pooler (port 5432) — used by Alembic migrations only.
# Supports prepared statements natively, required for DDL.
DATABASE_DIRECT_URL=postgresql+asyncpg://postgres.<ref>:<password>@aws-0-<region>.pooler.supabase.com:5432/postgres

SUPABASE_URL=https://<ref>.supabase.co
SUPABASE_SERVICE_ROLE_KEY=<service_role key>
SUPABASE_JWT_SECRET=<legacy HS256 shared secret — remove after revoking legacy key>

REDIS_URL=redis://localhost:6379
SECRET_KEY=<random 32+ chars>
ENVIRONMENT=development
CORS_ORIGINS=["http://localhost:5173"]
